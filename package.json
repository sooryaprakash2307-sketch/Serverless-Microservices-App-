{
  "name": "serverless-microservices-app",
  "version": "1.0.0",
  "description": "Serverless microservices web app with autoscaling and CI/CD",
  "main": "index.js",
  "scripts": {
    "test": "npm run test --workspaces",
    "deploy": "npm run deploy --workspaces",
    "build": "npm run build --workspaces",
    "dev": "serverless offline start",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "workspace:install": "npm install --workspaces",
    "test:smoke": "node scripts/smoke-tests.js"
  },
  "workspaces": ["services/*", "frontend"],
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0"
  },
  "keywords": ["serverless", "microservices", "aws", "lambda", "cicd"],
  "author": "",
  "license": "MIT"
}
